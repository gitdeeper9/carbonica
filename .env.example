# CARBONICA Environment Variables
# Advanced Planetary Carbon Accounting & Feedback Dynamics
# Version: 1.0.0 | DOI: 10.5281/zenodo.18995446

# ============================================
# Core Configuration
# ============================================
CARBONICA_ENV=development  # development, staging, production
CARBONICA_VERSION=1.0.0
CARBONICA_DATA_DIR=./data
CARBONICA_OUTPUT_DIR=./output
CARBONICA_LOG_DIR=./logs
CARBONICA_LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
CARBONICA_NUM_CORES=4

# ============================================
# Database Configuration (PostgreSQL/TimescaleDB)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=carbonica
DB_USER=carbonica_user
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=10
DB_TIMEOUT=30

# ============================================
# Redis Cache Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT=5

# ============================================
# API Configuration
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_TIMEOUT=60
API_RATE_LIMIT=100  # requests per minute
API_KEY=your_api_key_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=3600  # seconds

# ============================================
# Web Dashboard Configuration
# ============================================
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5000
DASHBOARD_DEBUG=false
DASHBOARD_UPDATE_INTERVAL=3600  # seconds
DASHBOARD_THEME=light

# ============================================
# Data Sources
# ============================================
# NOAA Keeling Curve
KEELING_URL=https://gml.noaa.gov/webdata/ccgg/trends/co2/co2_mm_mlo.txt
KEELING_LOCAL_PATH=./data/raw/keeling.csv
KEELING_UPDATE_FREQUENCY=monthly

# SOCAT Ocean CO2
SOCAT_VERSION=v2025
SOCAT_URL=https://www.socat.info/index.php/version-2025/
SOCAT_LOCAL_PATH=./data/raw/socat
SOCAT_UPDATE_FREQUENCY=yearly

# MODIS NPP
MODIS_PRODUCT=MOD17A2
MODIS_VERSION=6.1
MODIS_USER=your_earthdata_username
MODIS_PASSWORD=your_earthdata_password
MODIS_LOCAL_PATH=./data/raw/modis
MODIS_YEARS=2000-2025

# GTN-P Permafrost
GTNP_URL=https://gtnp.arcticportal.org/
GTNP_LOCAL_PATH=./data/raw/gtnp
GTNP_STATIONS=1240

# GLODAP Ocean Chemistry
GLODAP_VERSION=v2
GLODAP_URL=https://www.glodap.info/
GLODAP_LOCAL_PATH=./data/raw/glodap

# GOSAT SIF
GOSAT_PRODUCT=SIF
GOSAT_VERSION=latest
GOSAT_LOCAL_PATH=./data/raw/gosat
GOSAT_YEARS=2009-2025

# OCO-2 SIF
OCO2_PRODUCT=SIF
OCO2_VERSION=latest
OCO2_LOCAL_PATH=./data/raw/oco2
OCO2_YEARS=2014-2025

# FLUXNET
FLUXNET_URL=https://fluxnet.org/
FLUXNET_LOCAL_PATH=./data/raw/fluxnet

# ECMWF ERA5
ERA5_API_KEY=your_cds_api_key
ERA5_LOCAL_PATH=./data/raw/era5

# ============================================
# Processing Configuration
# ============================================
PROCESSING_PARALLEL=true
PROCESSING_NUM_WORKERS=4
PROCESSING_CHUNK_SIZE=1000
PROCESSING_MEMORY_LIMIT=4096  # MB
PROCESSING_CACHE_ENABLED=true
PROCESSING_CACHE_DIR=./cache
PROCESSING_ENSEMBLE_SIZE=10000

# ============================================
# PCSI Configuration
# ============================================
PCSI_WEIGHTS_FILE=./config/pcsi_weights.json
PCSI_UPDATE_FREQUENCY=monthly
PCSI_OUTPUT_FORMATS=csv,netcdf,json

# ============================================
# Machine Learning Configuration
# ============================================
ML_USE_GPU=false
ML_GPU_ID=0
ML_MODELS_DIR=./models
ML_TENSORFLOW_ENABLE=true
ML_PYTORCH_ENABLE=false
ML_RANDOM_SEED=42

# ============================================
# Alert Configuration
# ============================================
ALERTS_ENABLED=false
ALERTS_CHECK_INTERVAL=86400  # daily
ALERTS_THRESHOLD_PCSI=0.80
ALERTS_THRESHOLD_REVELLE=0.07  # acceleration per year
ALERTS_THRESHOLD_PERMAFLUX=0.12  # PgC/yr²

# Email Alerts
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_SMTP=smtp.gmail.com
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USER=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password
ALERT_EMAIL_RECIPIENTS=user1@example.com,user2@example.com

# Slack Alerts
ALERT_SLACK_ENABLED=false
ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx

# ============================================
# Grafana Configuration
# ============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3000

# ============================================
# Prometheus Configuration
# ============================================
PROMETHEUS_PORT=9091

# ============================================
# Security
# ============================================
SECRET_KEY=your_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here
ALLOWED_HOSTS=localhost,127.0.0.1,carbonica.netlify.app
CORS_ORIGINS=*

# ============================================
# Docker Configuration
# ============================================
DOCKER_IMAGE=gitdeeper9/carbonica:latest
DOCKER_NETWORK=carbonica-network
DOCKER_TIMESCALEDB_IMAGE=timescale/timescaledb:latest-pg15
DOCKER_REDIS_IMAGE=redis:7-alpine

# ============================================
# Netlify Configuration
# ============================================
NETLIFY_SITE_ID=your_netlify_site_id
NETLIFY_AUTH_TOKEN=your_netlify_auth_token

# ============================================
# ORCID
# ============================================
ORCID_ID=0009-0003-8903-0029
ORCID_NAME=Samir Baladi

# ============================================
# DO NOT COMMIT THIS FILE TO VERSION CONTROL
# ============================================
# Copy this file to .env and fill in your actual values
# .env is in .gitignore and will not be committed
